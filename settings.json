// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // theme
  "language_models": {
    "openai_compatible": {
      "muxufo": {
        "api_url": "http://muxufo.com/v1",
        "available_models": [
          {
            "name": "gemini-3-flash-preview",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          },
          {
            "name": "gemini-3-flash",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": true,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  // base keymap
  "base_keymap": null,
  // editor font
  "buffer_font_family": "JetBrains Mono NL",
  "buffer_font_size": 15.5,
  "edit_predictions": {
    "provider": "zed",
  },
  //UI font
  "agent_ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  "ui_font_family": "JetBrains Mono NL",
  "ui_font_size": 16.0,
  // 6.Code && Interface Display
  "unnecessary_code_fade": 0.3,
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.7,
  },
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "use_autoclose": true,
  "use_auto_surround": true,
  "use_smartcase_search": true,
  // 7.Application Behavior
  "agent": {
    "favorite_models": [
      {
        "provider": "muxufo",
        "model": "gemini-3-flash-preview",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false,
        "effort": "high"
      }
    ],
    "dock": "right",
    "default_profile": "ask",
    "expand_edit_card": true,
    "default_model": {
      "enable_thinking": false,
      "provider": "muxufo",
      "model": "gemini-3-flash-preview",
    },
    "model_parameters": [],
  },
  "auto_update": false,
  // 9.Editing Behavior
  "hard_tabs": false,
  "tab_size": 2,
  "remove_trailing_whitespace_on_save": true,
  "enable_language_server": true,
  "formatter": "language_server",
  "format_on_save": "off",
  // 10. Languages && Services
  "file_types": {
    "HTML": ["cshtml"],
  },
  "terminal": {
    "shell": {
      "program": "nu.exe",
    },
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "default",
      },
    },
    "copy_on_select": true,
  },
  "auto_install_extensions": {
    "html": true,
    "javascript": false,
  },
  "lsp": {
    "biome": {
      "settings": {
        "config_path": "C:/Users/lenovo/.config/biome.json",
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "exclude": ["*"],
        },
      },
    },
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "tab_size": 2,
    },
    "TypeScript": {
      "language_servers": ["biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
      "tab_size": 2,
    },
    "HTML": {
      "language_servers": ["biome"],
    },
    "JSON": {
      "language_servers": ["biome"],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "Python": {
      "language_servers": ["ruff", "pyright"],
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
  },
  // vim mode
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true,
  },
  "completions": {
    "words": "enabled", // use document's words for completions
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "github_token",
      },
    },
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
}
